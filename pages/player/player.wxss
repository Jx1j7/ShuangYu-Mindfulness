page {
  height: 100vh;
  width: 100vw;
  background-color: #1a1a2e;
}

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 导航栏 */
.nav-bar {
  width: 90%;
  padding-top: calc(env(status-bar-height) + 36rpx);
  display: flex;
  align-items: center;
  position: relative;
  z-index: 10;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.12);
  border-radius: 30rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: bold;
  margin-right: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.back-text {
  font-size: 28rpx;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.btn-active {
  opacity: 0.6;
}

/* 场景标题 */
.scene-title {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
  letter-spacing: 6rpx;
  margin-top: 24rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.5);
}

/* 浮动岛屿 */
.floating-img {
  background-color: transparent !important;
  width: 50%;
  height: auto;
  margin-top: 80rpx;
  animation: floating 3s ease-in-out infinite;
  filter: drop-shadow(0 16rpx 32rpx rgba(0, 0, 0, 0.3));
  position: relative;
  z-index: 1;
}

@keyframes floating {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

/* 点赞栏 */
.like-bar {
  margin-top: 48rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 10;
}

.like-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 32rpx;
  margin: 0 12rpx;
  background: rgba(255, 255, 255, 0.4) !important;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 40rpx !important;
  border: 2rpx solid rgba(255, 255, 255, 0.3) !important;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  font-size: inherit;
  line-height: normal;
}

.like-btn.liked {
  background: rgba(231, 76, 60, 0.35) !important;
  border-color: rgba(231, 76, 60, 0.5) !important;
}

.like-icon {
  font-size: 40rpx;
  margin-right: 10rpx;
}

.like-label {
  font-size: 26rpx;
  color: #333333;
}

/* 音量控制面板 */
.control-panel {
  width: 82%;
  margin-top: 80rpx;
  padding: 36rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.12);
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
  position: relative;
  z-index: 1;
}

.slider-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 0;
}

.slider-row + .slider-row {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}

.slider-label {
  font-size: 24rpx;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  width: 200rpx;
  flex-shrink: 0;
}

.vol-slider {
  flex: 1;
  margin: 0;
}

.slider-wrap {
  flex: 1;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  padding: 16rpx 20rpx;
}

/* 播放/暂停按钮 */
.play-btn-wrapper {
  margin-top: auto;
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
  position: relative;
  z-index: 1;
}

.play-btn {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(255, 255, 255, 0.15);
  -webkit-backdrop-filter: blur(15px);
  backdrop-filter: blur(15px);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.pause-btn {
  background-color: rgba(255, 255, 255, 0.15) !important;
  border: 2rpx solid rgba(255, 255, 255, 0.3) !important;
  -webkit-backdrop-filter: blur(15px) !important;
  backdrop-filter: blur(15px) !important;
}

.btn-press {
  transform: scale(0.9);
}

.play-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  text-shadow: 0 0 10rpx rgba(255, 255, 255, 0.5);
}
