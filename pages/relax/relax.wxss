/* 与导入页一致的上下对称淡绿色渐变背景 */
page {
  height: 100vh;
  background-image: linear-gradient(180deg, #D8F0E3 0%, #EAF6EE 14%, #FFFFFF 28%, #FFFFFF 65%, #EBFAF1 82%, #D8F0E3 100%);
}

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* 导航栏 - 返回按钮（全局统一位置） */
.nav-bar {
  width: 90%;
  padding-top: calc(env(status-bar-height) + 36rpx);
  display: flex;
  align-items: center;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #2C3E50;
  font-weight: bold;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #2C3E50;
}

.btn-active {
  opacity: 0.6;
}

/* 场景选项列表 - 视觉重心下移，饱满布局 */
.list {
  margin-top: 20vh;
  width: 90%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

/* 学科选项卡 */
.subject-card {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 32rpx;
  background-color: rgba(255, 255, 255, 0.45);
  border-radius: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.3);
}

.card-gap {
  margin-top: 120rpx;
}

.card-img {
  width: 40%;
  height: auto;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 放松主题 - 两座岛屿颜色区分 */
.card-img-anxiety {
  filter: hue-rotate(180deg) brightness(1.1);
}

.card-img-pain {
  filter: hue-rotate(280deg) saturate(0.8);
}

.card-text {
  margin-left: 32rpx;
  font-size: 48rpx;
  color: #34495E;
  font-weight: 500;
  font-family: "Songti SC", "Source Han Serif SC", "Noto Serif CJK SC", "STSong", "SimSun", serif;
  letter-spacing: 4rpx;
  flex: 1;
}

/* 点击反馈效果 */
.card-active {
  opacity: 0.7;
  transform: scale(0.98);
}
