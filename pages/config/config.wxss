page {
  height: 100vh;
  background-image: linear-gradient(180deg, #D8F0E3 0%, #EAF6EE 14%, #FFFFFF 28%, #FFFFFF 65%, #EBFAF1 82%, #D8F0E3 100%);
}

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
}

/* 导航栏 */
.nav-bar {
  width: 90%;
  padding-top: calc(env(status-bar-height) + 36rpx);
  display: flex;
  align-items: center;
}

.back-btn {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #34495E;
  font-weight: bold;
  margin-right: 4rpx;
}

.back-text {
  font-size: 28rpx;
  color: #34495E;
}

/* 推荐框 */
.recommend-box {
  width: 86%;
  margin-top: 40rpx;
  padding: 32rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.recommend-title {
  font-size: 26rpx;
  color: #7F8C8D;
  display: block;
  margin-bottom: 20rpx;
}

.recommend-tags {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}

.tag {
  padding: 14rpx 28rpx;
  background-color: rgba(44, 62, 80, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(44, 62, 80, 0.12);
  flex-shrink: 0;
}

.hover-active:active {
  opacity: 0.65;
  transform: scale(0.96);
}

.tag-text {
  font-size: 26rpx;
  color: #34495E;
  font-weight: 500;
  white-space: nowrap;
}

/* 配置区 */
.config-section {
  width: 86%;
  margin-top: 50rpx;
  padding: 36rpx 28rpx;
  background-color: rgba(255, 255, 255, 0.5);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.config-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.config-row + .config-row {
  border-top: 1rpx solid rgba(44, 62, 80, 0.08);
}

.tap-area:active .picker-value {
  background-color: rgba(44, 62, 80, 0.1);
}

.config-label {
  font-size: 30rpx;
  color: #34495E;
  font-weight: 500;
}

.picker-value {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: rgba(44, 62, 80, 0.04);
  border-radius: 12rpx;
  min-width: 200rpx;
  flex: 1;
  justify-content: space-between;
  transition: background-color 0.15s;
}

.picker-value text:nth-child(1) {
  font-size: 28rpx;
  color: #2C3E50;
}

.picker-arrow {
  font-size: 24rpx;
  color: #AAB7B8;
  margin-left: 12rpx;
}

/* 开始按钮 */
.start-wrapper {
  width: 86%;
  margin-top: auto;
  padding: 60rpx 0 calc(60rpx + env(safe-area-inset-bottom));
}

.start-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #5DADE2 0%, #2E86C1 100%);
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 12rpx;
  border-radius: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(46, 134, 193, 0.3);
  text-align: center;
  margin: 0;
  padding: 0;
  border: none;
}

.hover-press:active {
  opacity: 0.85;
  transform: scale(0.97);
}

/* ========== 自定义选择器弹窗 ========== */

/* 遮罩层 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0);
  transition: background-color 0.25s ease;
  z-index: 998;
  pointer-events: none;
}

.picker-mask.show {
  background-color: rgba(0, 0, 0, 0.45);
  pointer-events: auto;
}

/* 弹窗主体 */
.picker-popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 999;
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.36, 0.66, 0.04, 1);
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.picker-popup.show {
  transform: translateY(0);
}

/* 弹窗头部 */
.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #EEEEEE;
  flex-shrink: 0;
}

.picker-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: 600;
}

.picker-close {
  font-size: 28rpx;
  color: #5DADE2;
  font-weight: 500;
  padding: 8rpx 16rpx;
}

/* 选项列表 */
.picker-list {
  max-height: 50vh;
  padding: 16rpx 0 calc(16rpx + env(safe-area-inset-bottom));
}

.picker-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 40rpx;
  transition: background-color 0.15s;
}

.picker-option:active {
  background-color: #F5F5F5;
}

.picker-option.active .option-name {
  color: #5DADE2;
  font-weight: 600;
}

.option-name {
  font-size: 30rpx;
  color: #333333;
  transition: all 0.15s;
}

.option-check {
  font-size: 30rpx;
  color: #5DADE2;
  font-weight: bold;
}
