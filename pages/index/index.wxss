page {
  height: 100vh;
  width: 100vw;
  margin: 0;
  padding: 0;
  background-color: #F0F9F4;
}

.page-container {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-image: linear-gradient(180deg, #D8F0E3 0%, #EAF6EE 14%, #FFFFFF 28%, #FFFFFF 65%, #EBFAF1 82%, #D8F0E3 100%);
  overflow: hidden;
}

.content-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
}

.title-text {
  font-size: 72rpx;
  font-weight: 500;
  font-family: "Songti SC", "Source Han Serif SC", "Noto Serif CJK SC", "STSong", "SimSun", serif;
  background-image: linear-gradient(135deg, #3a7d5c 0%, #1a4d2e 40%, #0d2818 70%, #06120c 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  letter-spacing: 12rpx;
  margin-bottom: 12rpx;
  opacity: 0.75;
  text-align: center;
}

.logo-image {
  width: 60vw;
  height: auto;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.04);
  border-radius: 8rpx;
  margin-bottom: 60rpx;
}

.subtitle-text {
  font-size: 26rpx;
  color: #999999;
  font-weight: 300;
  opacity: 0.8;
}

.bottom-hint {
  position: absolute;
  bottom: calc(50px + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  pointer-events: none;
}

.hint-text {
  font-size: 24rpx;
  color: #bbbbbb;
  animation: breathe 3.5s ease-in-out infinite;
}

.footer-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.earphone-tip {
  font-size: 24rpx;
  color: rgba(0, 0, 0, 0.4);
  margin-bottom: 24rpx !important;
}

@keyframes breathe {
  0% { opacity: 0.2; }
  50% { opacity: 0.7; }
  100% { opacity: 0.2; }
}
