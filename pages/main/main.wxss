page {
  height: 100vh;
  background-image: linear-gradient(180deg, #D8F0E3 0%, #EAF6EE 14%, #FFFFFF 28%, #FFFFFF 65%, #EBFAF1 82%, #D8F0E3 100%);
}
.page {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.header {
  margin-top: 15vh;
  font-size: 44rpx;
  color: #2C3E50;
  font-weight: 500;
  letter-spacing: 8rpx;
}
.list {
  margin-top: 120rpx;
  width: 85%;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 48rpx 32rpx;
  background-color: rgba(255,255,255,0.4);
  border-radius: 24rpx;
  border: none;
}
.card-gap {
  margin-top: 80rpx;
}
.card-img {
  width: 280rpx;
  height: auto;
  border-radius: 12rpx;
  flex-shrink: 0;
}
.card-img-blue {
  filter: hue-rotate(30deg);
}
.card-text {
  margin-left: 36rpx;
  font-size: 52rpx;
  color: #2C3E50;
  font-weight: 500;
  font-family: "Songti SC", "Source Han Serif SC", "Noto Serif CJK SC", "STSong", "SimSun", serif;
  letter-spacing: 4rpx;
}
.card-active {
  transform: scale(0.95);
}
